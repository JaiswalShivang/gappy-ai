{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR-BACKEND-URL.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://YOUR-BACKEND-URL.up.railway.app/uploads/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://YOUR-BACKEND-URL.up.railway.app/static/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
